# Backend base URL. Defaults to http://localhost:8000 (simulator + adb-reverse).
# For a physical device, copy this to .env.local and set your dev machine's LAN
# IP, e.g. EXPO_PUBLIC_API_BASE=http://192.168.1.42:8000
# EXPO_PUBLIC_API_BASE=http://localhost:8000

# Firebase (Spark free plan) — from Firebase console ▸ Project settings ▸ Your apps (Web).
# All public-safe. Put real values in client/.env.local (gitignored).
# Backup uses Auth + Firestore (no Storage bucket — Storage needs the paid Blaze plan).
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
# EXPO_PUBLIC_FIREBASE_APP_ID=
