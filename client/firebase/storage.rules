// client/firebase/storage.rules
// Apply in Firebase console ▸ Storage ▸ Rules (or `firebase deploy --only storage`).
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
