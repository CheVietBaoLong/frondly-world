// client/firebase/firestore.rules
// Apply in Firebase console ▸ Firestore Database ▸ Rules.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Owner-only. Firestore denies any unmatched path by default, and rules are
    // OR-evaluated (not first-match), so no catch-all deny is needed.
    match /backups/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
