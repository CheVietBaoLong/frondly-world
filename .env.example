# Backend secrets — copy this file to `.env` at the repo root and fill in.
# Loaded by server/main.py (load_dotenv from the repo root). Never commit `.env`.

# Google Gemini API key — REQUIRED. Powers the plantcare ADK agent (diagnosis,
# chat) and Gemini vision (plant + forage identification). Without it the agent
# and identify endpoints won't work.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
